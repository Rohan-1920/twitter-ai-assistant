PORT=3000
TWITTER_EMAIL=your_email@example.com
TWITTER_USERNAME=your_twitter_handle
TWITTER_PASSWORD=your_password

# Headless by default (required on Render). Set false only for local debugging.
HEADLESS=true

# Twitter base URL
TWITTER_URL=https://x.com

# Reply monitor interval (ms) — 60–120s recommended
CHECK_INTERVAL=90000
REPLY_MONITOR_ENABLED=true
MAX_TRACKED_TWEETS=50

# OpenAI (required for auto-replies)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Playwright timeouts (ms)
PLAYWRIGHT_TIMEOUT_MS=45000

# Render session (choose ONE after `npm run login` locally):
# Option A — raw JSON (paste full file contents):
# STORAGE_STATE_JSON={"cookies":[...],"origins":[...]}
# Option B — base64 (recommended, run: npm run export-session):
# STORAGE_STATE_BASE64=eyJjb29raWVzIjpbLi4uXX0=
